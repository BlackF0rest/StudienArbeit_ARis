[Unit]
Description=ARis Chromium Kiosk (X11)
After=systemd-user-sessions.service aris-ui.service
Requires=aris-ui.service

[Service]
Type=simple
User=admin
Environment=HOME=/home/admin
Environment=ARIS_KIOSK_BROWSER=midori
WorkingDirectory=/home/admin
ExecStart=/usr/bin/startx /home/StudienArbeit_ARis/Software/deploy/pi/kiosk/start_onboard.sh -- :0 vt1
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
